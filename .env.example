# ==========================================
# Database Configuration
# ==========================================
POSTGRES_USER=gharsamma
POSTGRES_PASSWORD=<change-to-strong-password>
POSTGRES_DB=gharsamma

# ==========================================
# JWT Secrets (Generate secure random strings)
# Use: openssl rand -base64 32
# ==========================================
JWT_SECRET=<generate-with-openssl-rand-base64-32>
JWT_REFRESH_SECRET=<generate-with-openssl-rand-base64-32>

# ==========================================
# Cloudinary Configuration
# Get from https://cloudinary.com/console
# ==========================================
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# ==========================================
# Application URLs
# ==========================================
NEXT_PUBLIC_API_URL=https://api.gharsamma.com
NEXT_PUBLIC_WEB_URL=https://gharsamma.com
NEXT_PUBLIC_ADMIN_URL=https://admin.gharsamma.com

# ==========================================
# CORS Origins (comma-separated, no spaces)
# ==========================================
CORS_ORIGIN=https://gharsamma.com,https://admin.gharsamma.com,https://api.gharsamma.com

# ==========================================
# Upload Path (for Docker volume mount)
# ==========================================
UPLOAD_PATH=./uploads

# ==========================================
# Docker Registry (optional)
# ==========================================
# DOCKER_REGISTRY=theankitx
