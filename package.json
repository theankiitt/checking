{
  "name": "gharsamma-ecommerce",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "turbo run start --filter=@gharsamma/api --filter=web --filter=admin",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:push": "cd prisma && npx prisma db push",
    "db:seed": "cd prisma && npx ts-node --esm seed.ts",
    "db:studio": "cd prisma && npx prisma studio"
  },
  "prisma": {
    "seed": "ts-node --esm prisma/seed.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "critters": "^0.0.25",
    "react-hook-form": "^7.62.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "turbo": "^2.5.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
